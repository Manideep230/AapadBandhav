NODE_ENV=production
PORT=5000

# Database
DB_DIALECT=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=aapadbandhav_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0

# MQTT Broker (Self-hosted Mosquitto)
