# ─── Environment Template (AapadBandhav) ───────────────────────────────

NODE_ENV=production
PORT=5000

# ─── Database Settings ────────────────────────────────────────────────
DB_DIALECT=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=aapadbandhav_db
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password

# ─── Redis Cache / Message Broker Settings ───────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MQTT Telemetry Settings ──────────────────────────────────────────
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883
MQTT_USER=server
MQTT_PASSWORD=your_secure_mqtt_server_password
MQTT_NODE_USER=vehicle_node
MQTT_NODE_PASSWORD=your_secure_mqtt_node_password

# ─── JWT Authentication Settings ──────────────────────────────────────
JWT_SECRET=your_secure_64_character_random_string_here
JWT_EXPIRES_IN=7d

# ─── Admin Core Credentials ───────────────────────────────────────────
ADMIN_EMAIL=admin@aapadbandhav.in
ADMIN_PASSWORD=your_secure_admin_portal_password

# ─── Allowed CORS Domains (comma-separated list) ───────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ─── Firebase Push Notifications Setup ─────────────────────────────────
FIREBASE_PROJECT_ID=aapadbandhav
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@aapadbandhav.iam.gserviceaccount.com

# ─── SMS Twilio Gateway Credentials (Optional Fallback) ────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# ─── File Upload Limits ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
