{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/docs",
      "dest": "/api/swagger"
    },
    {
      "src": "/api/docs/(.*)",
      "dest": "/api/swagger"
    },
    {
      "src": "/api/openapi.json",
      "dest": "/api/swagger"
    },
    {
      "src": "/api/openapi/(.*)",
      "dest": "/api/swagger"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth"
    },
    {
      "src": "/api/accidents/(.*)",
      "dest": "/api/accidents"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/admin"
    },
    {
      "src": "/api/devices/(.*)",
      "dest": "/api/devices"
    },
    {
      "src": "/api/live-map/my-devices",
      "dest": "/api/devices"
    },
    {
      "src": "/api/iot/(.*)",
      "dest": "/api/iot"
    },
    {
      "src": "/api/inngest",
      "dest": "/api/inngest"
    },
    {
      "src": "/api/profile",
      "dest": "/api/profile"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/profile"
    },
    {
      "src": "/api/locations/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/alerts/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/hospitals/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/ambulances/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/police/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/mechanics/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/fire/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/volunteer/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/my/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/routes/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/insurance/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/api/health",
      "dest": "/api/locations"
    },
    {
      "src": "/api/health/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/health",
      "dest": "/api/locations"
    },
    {
      "src": "/health/(.*)",
      "dest": "/api/locations"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
