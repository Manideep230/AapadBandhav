{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "includeFiles": "node_modules/swagger-ui-dist/**"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/docs",           "destination": "/api/swagger" },
    { "source": "/api/docs/(.*)",       "destination": "/api/swagger" },
    { "source": "/api/openapi.json",    "destination": "/api/swagger" },
    { "source": "/api/openapi/(.*)",    "destination": "/api/swagger" },
    { "source": "/api/auth/(.*)",       "destination": "/api/auth" },
    { "source": "/api/accidents/(.*)",  "destination": "/api/accidents" },
    { "source": "/api/admin/(.*)",      "destination": "/api/admin" },
    { "source": "/api/devices/(.*)",    "destination": "/api/devices" },
    { "source": "/api/live-map/my-devices", "destination": "/api/devices" },
    { "source": "/api/iot/(.*)",        "destination": "/api/iot" },
    { "source": "/api/profile",         "destination": "/api/profile" },
    { "source": "/api/users/(.*)",      "destination": "/api/profile" },
    { "source": "/api/locations/(.*)",  "destination": "/api/locations" },
    { "source": "/api/notifications",   "destination": "/api/locations" },
    { "source": "/api/notifications/(.*)", "destination": "/api/locations" },
    { "source": "/api/alerts/(.*)",     "destination": "/api/locations" },
    { "source": "/api/hospitals/(.*)",  "destination": "/api/locations" },
    { "source": "/api/ambulances/(.*)", "destination": "/api/locations" },
    { "source": "/api/police/(.*)",     "destination": "/api/locations" },
    { "source": "/api/mechanics/(.*)",  "destination": "/api/locations" },
    { "source": "/api/fire/(.*)",       "destination": "/api/locations" },
    { "source": "/api/volunteer/(.*)",  "destination": "/api/locations" },
    { "source": "/api/my/(.*)",         "destination": "/api/locations" },
    { "source": "/api/routes",          "destination": "/api/locations" },
    { "source": "/api/routes/(.*)",     "destination": "/api/locations" },
    { "source": "/api/insurance/(.*)",  "destination": "/api/locations" },
    { "source": "/api/health",          "destination": "/api/locations" },
    { "source": "/api/health/(.*)",     "destination": "/api/locations" },
    { "source": "/health",              "destination": "/api/locations" },
    { "source": "/health/(.*)",         "destination": "/api/locations" },
    { "source": "/((?!api|assets|favicon\\.ico).*)", "destination": "/index.html" }
  ]
}
