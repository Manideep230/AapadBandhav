{
  "name": "aapadbandhav",
  "version": "1.0.0",
  "description": "AapadBandhav - Smart Accident Detection & Emergency Response Platform",
  "main": "index.js",
  "scripts": {
    "dev:backend": "ts-node local_server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "prisma:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema=backend/prisma/schema.prisma",
    "prisma:seed": "prisma db seed",
    "build": "ts-node backend/api/swagger/generate.ts && cd frontend && npm install && cd .. && npm run prisma:generate && npm run build:frontend",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.39.8",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.6",
    "inngest": "^3.15.5",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.10.0",
    "pusher": "^5.2.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "4.6.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.8.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "ts-node backend/prisma/seed.ts"
  }
}
